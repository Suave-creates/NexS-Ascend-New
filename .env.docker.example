# Copy to `.env.docker` and edit. Defaults target the bundled MySQL service
# (compose hostname "db"). Values here are read by the app container at runtime
# (docker-compose `env_file`). NEVER commit the real .env.docker.

# Provision the local MySQL with each Prisma schema on startup (local runs).
# Set to false in production where the databases already exist.
RUN_DB_PUSH=true

# If you change this, also update the passwords in the connection strings below.
MYSQL_ROOT_PASSWORD=nexs_root_pw

# ── Prisma datasources ──────────────────────────────────────────────────────
DATABASE_URL=mysql://root:nexs_root_pw@db:3306/nexs_mydb
DATABASE_URL_DISPATCH=mysql://root:nexs_root_pw@db:3306/nexs_dispatch
DATABASE_URL_LENS_LAB=mysql://root:nexs_root_pw@db:3306/nexs_lens_lab
DATABASE_URL_MF=mysql://root:nexs_root_pw@db:3306/nexs_metal_frame
# onSite datasource client is currently unused; set only if you enable it.
# ON_SITE_DB_URL=mysql://root:nexs_root_pw@db:3306/nexs_onsite

# ── Raw mysql2 pools (WAREHOUSE data — external in production) ───────────────
# Local dev: these point at the bundled docker MySQL (no external network
# needed). Leave as-is unless you're testing against real warehouse data.
NexS_DB=mysql://root:nexs_root_pw@db:3306/nexs_mydb
NexS_DB_PICKING=mysql://root:nexs_root_pw@db:3306/nexs_mydb
#
# Production: instead of pointing NexS_DB/NexS_DB_PICKING at a raw external
# IP with a static credential, set the matching *_ADAPTIVE_ENDPOINT var below.
# When set, it takes priority and the app reaches the warehouse DB through
# Lenskart's Adaptive PAM CLI (`adaptive exec <endpoint> -c "<sql>"`) instead -
# see src/utils/adaptiveExecPool.ts for how the pool/connection API is
# preserved so no call sites needed to change.
#
# Requirements this repo does NOT set up for you:
#   1. The `adaptive` CLI binary must be on PATH inside the running container.
#   2. Someone must run `adaptive login -u https://adaptive.lenskart.com` once,
#      interactively (browser auth), inside that container - login is one-time;
#      the resulting ~/.adaptive token is reused after that (see the
#      adaptive_token volume in docker-compose.yml, mounted at the app
#      container's $HOME/.adaptive so the token survives restarts).
#   3. If a query ever fails because the token expired, the app logs
#      "Ask ARYA to reauthenticate the Adaptive token" - rerun the login
#      command above in the running container when you see that.
# NEXS_DB_ADAPTIVE_ENDPOINT=mysql_ro_nexs-slave02.prod.internal
# NEXS_DB_PICKING_ADAPTIVE_ENDPOINT=mysql_ro_nexs-picking-mysql-slavedb

# ── bosch_cv_db (src/lib/db.ts) ─────────────────────────────────────────────
BOSCH_DB_HOST=db
BOSCH_DB_PORT=3306
BOSCH_DB_USER=root
BOSCH_DB_PASSWORD=nexs_root_pw
BOSCH_DB_NAME=bosch_cv_db

# ── App ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
BQ_PROJECT_ID=lenskart-datahub
# Python interpreter used by the NDD-RCA route (venv baked into the image).
NDD_RCA_PYTHON=/opt/venv/bin/python

# ConsolidAte Order QC dump auth (primary — server logs in to NexS and auto-refreshes
# the jwt-token; no cookie paste, no extension, works on any origin).
# CONFIRMED working shape (login returns the JWT in the response `content` field):
#   - body is exactly {"userName","password"}  (strict schema)
#   - x-lenskart-app-id header identifies the app;  nexs-analytics works for login
#   - NEXS_USERNAME is the emp-code (e.g. 197531), NOT the email
# NEXS_AUTH_URL=https://app.nexs.lenskart.com/v1/user/login
# NEXS_USERNAME=197531
# NEXS_PASSWORD=...
# NEXS_APP_ID=nexs-analytics
# NEXS_FACILITY=NXS1
# NEXS_WORKSTATION=QC01
# NEXS_AUTH_BODY={"userName":"{USERNAME}","password":"{PASSWORD}"}   # optional; this is the default

# CL/CLS QC runner (user credentials are entered in the panel and never stored)
# CL_CLS_QC_URL=https://app.nexs.lenskart.com/qc
# CL_CLS_LOGIN_URL=https://app.nexs.lenskart.com/login
# CL_CLS_QC_PROFILE_DIR=./data/cl-cls-qc-profile
# CL_CLS_QC_BROWSER_CHANNEL=chrome
# CL_CLS_QC_HEADLESS=false

# ── Build-time only (set via compose build args, shown here for reference) ────
# NEXT_PUBLIC_AGENT_URL is inlined at build time; set it in the shell before
# `docker compose build`, e.g.  NEXT_PUBLIC_AGENT_URL=https://agent.example.com
