# Copy to `.env.docker` and edit. Defaults target the bundled MySQL service
# (compose hostname "db"). Values here are read by the app container at runtime
# (docker-compose `env_file`). NEVER commit the real .env.docker.

# Provision the local MySQL with each Prisma schema on startup (local runs).
# Set to false in production where the databases already exist.
RUN_DB_PUSH=true

# If you change this, also update the passwords in the connection strings below.
MYSQL_ROOT_PASSWORD=nexs_root_pw

# ── Prisma datasources ──────────────────────────────────────────────────────
DATABASE_URL=mysql://root:nexs_root_pw@db:3306/nexs_mydb
DATABASE_URL_DISPATCH=mysql://root:nexs_root_pw@db:3306/nexs_dispatch
DATABASE_URL_LENS_LAB=mysql://root:nexs_root_pw@db:3306/nexs_lens_lab
DATABASE_URL_MF=mysql://root:nexs_root_pw@db:3306/nexs_metal_frame
# onSite datasource client is currently unused; set only if you enable it.
# ON_SITE_DB_URL=mysql://root:nexs_root_pw@db:3306/nexs_onsite

# ── Raw mysql2 pools (WAREHOUSE data — external in production) ───────────────
# For a real deployment point these at the actual warehouse/WMS databases.
NexS_DB=mysql://root:nexs_root_pw@db:3306/nexs_mydb
NexS_DB_PICKING=mysql://root:nexs_root_pw@db:3306/nexs_mydb

# ── bosch_cv_db (src/lib/db.ts) ─────────────────────────────────────────────
BOSCH_DB_HOST=db
BOSCH_DB_PORT=3306
BOSCH_DB_USER=root
BOSCH_DB_PASSWORD=nexs_root_pw
BOSCH_DB_NAME=bosch_cv_db

# ── App ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
BQ_PROJECT_ID=lenskart-datahub
# Python interpreter used by the NDD-RCA route (venv baked into the image).
NDD_RCA_PYTHON=/opt/venv/bin/python

# ConsolidAte Order QC dump auth (primary — server logs in to NexS and auto-refreshes
# the jwt-token; no cookie paste, no extension, works on any origin):
# NEXS_AUTH_URL=https://app.nexs.lenskart.com/...        # the login POST endpoint
# NEXS_USERNAME=arya.khadgi2@lenskart.com
# NEXS_PASSWORD=...
# NEXS_FACILITY=NXS1
# NEXS_WORKSTATION=QC01
# NEXS_AUTH_BODY={"username":"{USERNAME}","password":"{PASSWORD}"}   # optional, if body differs
#
# Fallback only (if you can't do server login): a full cookie header incl. jwt-token.
# NEXS_COOKIE=jwt-token=eyJ...

# ── Build-time only (set via compose build args, shown here for reference) ────
# NEXT_PUBLIC_AGENT_URL is inlined at build time; set it in the shell before
# `docker compose build`, e.g.  NEXT_PUBLIC_AGENT_URL=https://agent.example.com
