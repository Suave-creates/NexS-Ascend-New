{
  "manifest_version": 3,
  "name": "DO Order Visibility",
  "version": "2.0.0",
  "description": "Live DO pendency dashboard — shipment and PID level visibility for NXS1 BULKTOVENDOR channel.",

  "permissions": [
    "cookies",
    "tabs"
  ],

  "host_permissions": [
    "https://app.nexs.lenskart.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_title": "DO Order Visibility — Open Dashboard",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
