{
  "manifest_version": 3,
  "name": "NEXS Sensitive PID Watcher",
  "version": "1.0.0",
  "description": "Silently watches NEXS getFittingDetail responses and flashes a full-screen police-siren alert when a configured sensitive product_id or lens_package appears.",
  "browser_specific_settings": {
    "gecko": {
      "id": "nexs-pid-watcher@bhiwadi-ops",
      "strict_min_version": "128.0"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://app.nexs.lenskart.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sensitive PID Watcher"
  },
  "content_scripts": [
    {
      "matches": ["https://app.nexs.lenskart.com/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://app.nexs.lenskart.com/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
